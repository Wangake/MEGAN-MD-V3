# ===== FEATURE MASTER SWITCHES =====
AUTO_REACT=off
AUTO_READ=off
AUTO_BIO=off
ANTI_DELETE=on          # on/off/inchat/indm
ANTI_LINK=off
ANTI_CALL=off
CHATBOT=off

# ===== AUTO-REACT SETTINGS =====
AUTO_REACT_PM=off
AUTO_REACT_GROUP=off

# ===== AUTO-READ SETTINGS =====
AUTO_READ_PM=off
AUTO_READ_GROUP=off

# ===== ANTI-LINK SETTINGS =====
ANTI_LINK_ACTION=delete   # delete/warn/kick
ANTI_LINK_WARNING=3
ANTI_LINK_MESSAGE=⚠️ Links are not allowed in this group!

# ===== ANTI-CALL SETTINGS =====
ANTI_CALL_MESSAGE=📞 Calls are not allowed! I will reject your call.

# ===== PRESENCE SETTINGS =====
PRESENCE_PM=typing        # online/typing/recording/offline
PRESENCE_GROUP=typing
AUTO_TYPING=off           # dm/group/both/off
AUTO_RECORDING=off        # dm/group/both/off

# ===== STATUS FEATURES =====
AUTO_VIEW_STATUS=on
AUTO_DOWNLOAD_STATUS=off
AUTO_REACT_STATUS=off
STATUS_REACT_EMOJIS=💛,❤️,💜,🤍,💙,👍,🔥
AUTO_REPLY_STATUS=off
STATUS_REPLY_TEXT=✅ Status viewed via Megan-MD
AUTO_SAVE_STATUS=off
AUTO_VIEW_ONCE=off

# ===== WELCOME/GOODBYE =====
WELCOME=off
WELCOME_MESSAGE=Hey @user welcome to our group! Hope you enjoy and connect with everyone.
WELCOME_AUDIO=off
GOODBYE=off
GOODBYE_MESSAGE=Goodbye @user! 👋
GOODBYE_AUDIO=off

# ===== STICKER SETTINGS =====
PACK_NAME=MEGAN-MD
PACK_AUTHOR=Wanga

# ===== PRIVACY SETTINGS =====
LAST_SEEN=all
PROFILE_PIC=all
STATUS_PRIVACY=all
READ_RECEIPTS=all
ONLINE_PRIVACY=all
BLOCK_UNKNOWN=off
BLOCK_PRIVATE=off

# ===== AI SETTINGS =====
AI_MODE=normal
AI_MODEL=@cf/meta/llama-3.1-8b-instruct

# ===== API ENDPOINTS (These will be loaded from megan/developer.js) =====
