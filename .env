SESSION=Megan~H4sIAAAAAAAAA...

# ===== BOT IDENTITY =====
BOT_NAME=𝐌𝐄𝐆𝐀𝐍-𝐌𝐃
OWNER_NAME=Wanga
OWNER_NUMBER=254758476795
PREFIX=.
MODE=public
TIMEZONE=Africa/Nairobi
FOOTER=© 𝐌𝐄𝐆𝐀𝐍-𝐌𝐃

# ===== SUDO NUMBERS (Extra owners, comma separated) =====
